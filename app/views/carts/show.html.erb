<h1>Your Cart</h1>

<% if @cart_items.any? %>
  <table>
    <thead>
      <tr>
        <th>Product</th>
        <th>Quantity</th>
        <th>Update</th>
        <th>Remove</th>
      </tr>
    </thead>
    <tbody>
<% @cart_items.each do |item| %>
        <tr>
          <td><%= item.product.name %></td>
          
          <td>
            <%= form_with(model: item, url: cart_line_item_path(item), method: :patch, local: true) do |f| %>
              <%= f.number_field :quantity, value: item.quantity, min: 1 %>
              <%= f.submit "Update" %>
            <% end %>
          </td>

          <td>
            <%= button_to "Remove", cart_line_item_path(item), method: :delete, data: { confirm: "Are you sure?" } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <p><strong>Total:</strong> <%= number_to_currency(@cart.total_price) %></p>

<% else %>
  <p>Your cart is empty.</p>
<% end %>
