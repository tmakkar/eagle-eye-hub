<h1>Order Summary</h1>

<p>Total: <%= number_to_currency(@order.total) %></p>

<ul>
  <% @order.order_items.each do |item| %>
    <li>
      <%= item.product.name %> - <%= item.quantity %> × <%= number_to_currency(item.price) %>
    </li>
  <% end %>
</ul>

<div class="container mt-4">
  <div class="row">
    <!-- Left: Image -->
    <div class="col-md-6">
      <%= image_tag(@product.image_url.presence || 'placeholder.png', class: "img-fluid", alt: @product.name) %>
    </div>

    <!-- Right: Product details -->
    <div class="col-md-6">
      <h1><%= @product.name %></h1>
      <p class="lead"><%= number_to_currency(@product.price) %></p>
      <p><%= @product.description %></p>

      <%= link_to 'Back to Products', products_path, class: 'btn btn-outline-secondary' %>
    </div>
  </div>
</div>
