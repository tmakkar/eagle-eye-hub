<h1>Admin::Dashboard#index</h1>
<p>Find me in app/views/admin/dashboard/index.html.erb</p>
<h2>Product Management</h2>
<%= link_to "Manage Products", products_path, class: "btn btn-primary" %>

<div class="filters">
  <%= link_to "All Products", products_path %> |
  <%= link_to "On Sale", products_path(filter: "on_sale") %> |
  <%= link_to "New Arrivals", products_path(filter: "new") %> |
  <%= link_to "Recently Updated", products_path(filter: "updated") %>
</div>

<% if product.image.attached? %>
  <%= image_tag product.image.variant(resize_to_limit: [300, 300]) %>
<% else %>
  <%= image_tag "placeholder.png", width: 100 %>
<% end %>

<%= paginate @products %>
