<p style="color: green"><%= notice %></p>

<% content_for :title, "Products" %>

<h1>Products</h1>

<div id="products">
  <% @products.each do |product| %>
    <%= render product %>
    <p>
      <%= link_to "Show this product", product %>
    </p>
  <% end %>
</div>

<%= link_to "New product", new_product_path %>

<h1>All Products</h1>
<% @products.each do |product| %>
  <div class="product-card">
    <% if product.image_url.present? %>
      <%= image_tag product.image_url, width: 100 %>
    <% else %>
      <%= image_tag "placeholder.png", width: 100 %> <!-- Make sure you have a placeholder image in app/assets/images -->
    <% end %>
    <h2><%= link_to product.name, product_path(product) %></h2>
    <p><%= number_to_currency(product.price) %></p>
  </div>
<% end %>

<%= form_with url: products_path, method: :get, local: true do %>
  <%= label_tag :search, "Search Products:" %>
  <%= text_field_tag :search, params[:search] %>

  <%= label_tag :category_id, "Filter by Category:" %>
  <%= select_tag :category_id, options_from_collection_for_select(Category.all, :id, :name, params[:category_id]), include_blank: "All Categories" %>

  <%= submit_tag "Search" %>
<% end %>

<main class="container">
  <h1>All Products</h1>
  <div class="row">
    <% @products.each do |product| %>
      <article class="col-md-4">
        <div class="card mb-3">
          <%= image_tag(product.image_url.presence || 'placeholder.png', class: "card-img-top", alt: product.name) %>
           <div class="card-body">
            <h5 class="card-title"><%= product.name %></h5>
            <p class="card-text">$<%= product.price %></p>
            <%= link_to 'View Details', product_path(product), class: 'btn btn-primary' %>
          </div>
        </div>
      </article>
    <% end %>
  </div>
</main>