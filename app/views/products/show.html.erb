<p style="color: green"><%= notice %></p>

<div>
  <%= link_to "Edit this product", edit_product_path(@product) %> |
  <%= link_to "Back to products", products_path %>
  <%= button_to "Destroy this product", @product, method: :delete %>
</div>

<h1><%= @product.name %></h1>
<%= image_tag(@product.image_url.presence || "placeholder.png", width: 200) %>
<p><strong>Price:</strong> <%= number_to_currency(@product.price) %></p>
<p><strong>Description:</strong> <%= @product.description %></p>
<p><strong>Stock:</strong> <%= @product.stock_quantity %></p>
<p><strong>Category:</strong> <%= @category.name %></p>
